{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "vitest run",
    "test:ui": "vitest run -c vitest.ui.config.ts",
    "test:all": "vitest run",
    "lint": "eslint --cache",
    "lint:fast": "oxlint --ignore-pattern 'tests/**' --nextjs-plugin --react-plugin --react-perf-plugin",
    "check:deps": "depcheck",
    "format:fast": "oxfmt --write .",
    "type-check": "tsc --noEmit",
    "type-check:fast": "npx tsgo --noEmit",
    "security-check": "npm audit --audit-level=high && secretlint \"**/*\""
  },
  "dependencies": {
    "next": "^16.2.6",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.41",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260523.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "babel-plugin-react-compiler": "1.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "prettier": "^3.8.1",
    "secretlint": "^13.0.2",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
