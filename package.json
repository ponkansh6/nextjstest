{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "tsgo": "tsgo",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:ui": "vitest run -c tests/vitest.ui.config.ts",
    "test:all": "bun test && vitest run -c tests/vitest.ui.config.ts",
    "lint": "eslint --cache",
    "lint:fast": "oxlint --ignore-pattern 'tests/**' --ignore-pattern 'scripts/ts_converters/**' --nextjs-plugin --react-plugin --react-perf-plugin",
    "check:deps": "depcheck",
    "format:fast": "oxfmt --write .",
    "type-check": "tsc --noEmit",
    "type-check:fast": "tsgo --noEmit",
    "security-check": "pnpm audit --audit-level=high && secretlint \"**/*\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "arquero": "^8.0.3",
    "iconv-lite": "^0.7.2",
    "next": "^16.2.9",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "recharts": "^3.9.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.43",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "secretlint": "12.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
