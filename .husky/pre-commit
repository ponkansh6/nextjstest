#!/bin/sh

echo "Running pre-commit checks (excluding tests)..."

# Check for unstaged changes
if [ -n "$(git diff --name-only)" ]; then
  echo "Error: You have unstaged changes. Please stage them using 'git add' before committing."
  exit 1
fi

# 1. Fast Linting (oxlint)
npm run lint:fast

# 2. Dependency Check (depcheck)
npm run check:deps

# 3. Fast Formatting (oxfmt) - Exclude tests
npx oxfmt --write . "!tests/**"

# 3. Fast Type Checking (tsgo) - Excludes tests via tsconfig.json
npm run type-check:fast

# 4. Logic Tests
echo "Running logic tests..."
npm run test -- --changed
