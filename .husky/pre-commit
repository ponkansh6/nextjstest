#!/bin/sh

echo "Running pre-commit checks..."

# 1. 未ステージの変更チェック
if [ -n "$(git diff --name-only)" ]; then
  echo "Error: Unstaged changes detected. Please stage them before committing."
  exit 1
fi

# 2. 静的解析・整合性チェック
npm run lint:fast
npm run check:deps

# 3. コードフォーマット・型チェック
npx oxfmt --write . "!tests/**"
npm run type-check:fast

# 4. 関連テストの実行
echo "Running relevant logic tests..."
npm run test -- --changed
