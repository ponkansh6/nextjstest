#!/bin/sh

# nvm の読み込み（フック実行環境では .bashrc 等が読まれないため必須）
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
nvm use 22

echo "Running pre-commit checks..."

# 1. 未ステージの変更チェック
if [ -n "$(git diff --name-only)" ]; then
  echo "Error: Unstaged changes detected. Please stage them before committing."
  exit 1
fi

# 2. 静的解析・整合性チェック
pnpm run lint:fast

# 3. コードフォーマット・型チェック
pnpm oxfmt --write . "!tests/**"
pnpm run type-check:fast

# 4. 関連テストの実行
echo "Running relevant logic tests..."
pnpm run test -- --changed
